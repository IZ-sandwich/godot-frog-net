[node name="LocalBall" type="RigidBody3D" unique_id=1602080397]
collision_layer = 2
collision_mask = 3
physics_material_override = SubResource("PhysicsMaterial_ball")
linear_damp = 0.4
angular_damp = 0.8

; VisualRoot wraps the mesh as a regular (non-top_level) child so Godot's
; SceneTreeFTI lerps it in lockstep with the body's other inherited children
; every render frame. The smoother writes Visual.GlobalPosition = body.GlobalPosition
; + offset; Godot internally computes the corresponding local Position relative
; to the body, so the mesh tracks the body's interpolated render-frame pose plus
; the (decaying) offset. Mirrors LocalCube.tscn's wiring — without this, every
; PRED-RECONCILE / spawn-catchup / blend-step body motion renders directly,
; producing the visible jitter observed on balls (eid >= 22) in S7-C2.
[node name="VisualRoot" type="Node3D" parent="." unique_id=1602080600]

[node name="MeshInstance3D" type="MeshInstance3D" parent="VisualRoot" unique_id=683380154]
mesh = SubResource("SphereMesh_rf2cd")

[node name="CollisionShape3D" type="CollisionShape3D" parent="." unique_id=2065844183]
shape = SubResource("SphereShape3D_a814b")

[node name="PredictionVisualSmoothing" type="Node3D" parent="." unique_id=1602080700 node_paths=PackedStringArray("Body", "Visual")]
script = ExtResource("4_smooth")
Body = NodePath("..")
Visual = NodePath("../VisualRoot")
metadata/_custom_type_script = "uid://rp5ifdkt35gg"

[node name="PredictionRigidbody" type="Node" parent="." unique_id=1602080500 node_paths=PackedStringArray("_body", "_smoothing")]
script = ExtResource("3_predrb")
_body = NodePath("..")
_smoothing = NodePath("../PredictionVisualSmoothing")
metadata/_custom_type_script = "uid://o8fwa7kmma11"

[node name="ClientPredictedEntity" type="Node" parent="." unique_id=1958913607 node_paths=PackedStringArray("_predictionRb")]
