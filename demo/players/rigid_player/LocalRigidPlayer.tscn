; Visible body mesh sized + positioned to match CollisionShape3D so the player
; is visible in the test recordings (otherwise the rigid-player scene was a
; collision-only invisible body). Layer is set so the player's own first-person
; camera (cull mask default) can hide it via its own cull mask config if a
; consumer cares about not seeing their own body — for the test's observer
; camera (cull_mask=all) it's always rendered.
[node name="VisualMesh" type="MeshInstance3D" parent="." unique_id=1602080707]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1, 0)
layers = 2
mesh = SubResource("CapsuleMesh_rplyr")

[node name="PredictionRigidbody" type="Node" parent="." unique_id=1602080702 node_paths=PackedStringArray("_body")]
script = ExtResource("2_predrb")
_body = NodePath("..")
metadata/_custom_type_script = "uid://o8fwa7kmma11"

[node name="ClientPredictedEntity" type="Node" parent="." unique_id=1602080703 node_paths=PackedStringArray("_predictionRb")]
script = ExtResource("1_lrpp")
_predictionRb = NodePath("../PredictionRigidbody")
metadata/_custom_type_script = "uid://2rptuj0wp7kx"

[node name="RotationHelperY" type="Node3D" parent="." unique_id=1602080704]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1.8, 0)
metadata/_edit_lock_ = true

[node name="Camera" type="Camera3D" parent="RotationHelperY" unique_id=1602080705]
; cull_mask omits layer 2 (1048575 - 2 = 1048573) so the player's own VisualMesh
; (placed on layer 2) doesn't block this first-person view. The harness's
; observer camera uses the default cull_mask and so still renders the body.
cull_mask = 1048573
current = true
fov = 90.0
script = ExtResource("3_camera")

[node name="PlayerInputProducer" type="Node" parent="." unique_id=1602080706 node_paths=PackedStringArray("_cameraController")]
script = ExtResource("4_input")
_cameraController = NodePath("../RotationHelperY/Camera")
